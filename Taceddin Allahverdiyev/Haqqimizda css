.text-box,
.contact-box {
    max-width: 700px;
    margin: 0 auto;
    background-color: #ffffff;
    border: 1px solid #b8d8ef;
    padding: 24px;
    border-radius: 8px;
}

.contact-box p {
    margin: 12px 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

.contact-icon {
    font-size: 20px;
}
